# OmniDownloader Environment Configuration

# Server Port
PORT=3050

# --- PATH CONFIGURATIONS ---
# Update these paths according to your system environment

# Path to the directory containing yt-dlp.exe, spotdl.exe, and gallery-dl.exe
# Example (Windows): C:\Users\YourUser\AppData\Local\Programs\Python\Python312\Scripts
# Example (Linux/Mac): /usr/local/bin
PYTHON_SCRIPTS_DIR=C:\Users\YourUser\AppData\Local\Programs\Python\Python312\Scripts

# Path to the directory containing ffmpeg.exe
# Example (Windows): C:\ffmpeg\bin
# Example (Linux/Mac): /usr/bin
FFMPEG_DIR=C:\ffmpeg\bin
